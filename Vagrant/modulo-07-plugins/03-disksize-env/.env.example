# =============================================================
# ARQUIVO: .env.example
# PROPÓSITO: Template com variáveis de ambiente para o projeto
# USO: Copie para .env e preencha com seus valores reais
#
# IMPORTANTE: NUNCA commite o arquivo .env no Git!
# Adicione ao .gitignore: echo ".env" >> .gitignore
# =============================================================

# Recursos da VM
VM_MEMORY=2048
VM_CPUS=2

# Credenciais do banco de dados
DB_NAME=meuapp
DB_USER=appuser
DB_PASSWORD=MUDE_ESTA_SENHA_AGORA

# Configurações da aplicação
APP_ENV=development
APP_PORT=3000
APP_DEBUG=true

# APIs externas (nunca exponha em repositórios públicos!)
# STRIPE_KEY=sk_test_...
# SENDGRID_API_KEY=SG....
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=...
