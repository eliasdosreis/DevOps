<?xml version="1.0" encoding="UTF-8"?>

<!-- ============================================================
  ARQUIVO: 01-pom-dependencias.xml
  RENOMEIE PARA: pom.xml

  O QUE ESTE ARQUIVO FAZ:
  Demonstra como declarar dependências no Maven com
  diferentes escopos (scopes).

  ANALOGIA:
  Imagine que você está montando uma loja física:
  - Alguns itens ficam NA LOJA o tempo todo (compile)
  - Alguns itens são usados apenas para MONTAR a loja,
    não ficam expostos aos clientes (provided)
  - Alguns itens chegam apenas DURANTE O FUNCIONAMENTO
    (runtime)
  - Ferramentas usadas apenas para INSPECIONAR a loja
    antes da abertura (test)

  DEFINIÇÃO TÉCNICA:
  scope no Maven define em quais classpath a dependência
  estará disponível: compile-time, runtime, test, etc.
  ============================================================ -->

<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0
                             https://maven.apache.org/xsd/maven-4.0.0.xsd">

  <modelVersion>4.0.0</modelVersion>
  <groupId>com.curso</groupId>
  <artifactId>hello-dependencias</artifactId>
  <version>1.0.0-SNAPSHOT</version>

  <properties>
    <maven.compiler.release>21</maven.compiler.release>
    <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>

    <!-- BOAS PRÁTICAS: centralize as versões em properties -->
    <!-- Facilita atualização e evita versões diferentes da mesma lib -->
    <junit.version>5.10.1</junit.version>
    <slf4j.version>2.0.9</slf4j.version>
    <logback.version>1.4.14</logback.version>
    <lombok.version>1.18.30</lombok.version>
    <h2.version>2.2.224</h2.version>
  </properties>

  <!-- ═══════════════════════════════════════════════════════
    SEÇÃO: dependencies
    Lista TODAS as dependências do projeto.

    Estrutura de uma dependência:
      <dependency>
        <groupId>...</groupId>       ← G do GAV (quem fez)
        <artifactId>...</artifactId> ← A do GAV (o quê)
        <version>...</version>       ← V do GAV (qual versão)
        <scope>...</scope>           ← Quando usar
      </dependency>
    ═══════════════════════════════════════════════════════ -->
  <dependencies>

    <!-- ─────────────────────────────────────────────────────
      ESCOPO: compile (PADRÃO, não precisa declarar)

      Disponível em: compilação + runtime + empacotamento + teste
      Entra no JAR final: SIM
      Uso típico: biblioteca que você usa no código de produção

      Exemplo: Gson para serializar JSON em produção
      ───────────────────────────────────────────────────── -->
    <dependency>
      <groupId>com.google.code.gson</groupId>
      <artifactId>gson</artifactId>
      <version>2.10.1</version>
      <!-- <scope>compile</scope> → compile é o padrão, pode omitir -->
    </dependency>

    <!-- SLF4J API — apenas a interface de logging (compile) -->
    <!-- A implementação vem via runtime (veja abaixo) -->
    <dependency>
      <groupId>org.slf4j</groupId>
      <artifactId>slf4j-api</artifactId>
      <version>${slf4j.version}</version>
      <!-- Usando property definida em <properties> → boa prática! -->
    </dependency>

    <!-- ─────────────────────────────────────────────────────
      ESCOPO: runtime

      Disponível em: runtime + empacotamento + teste
      NÃO disponível em: compilação (não aparece nas classes .java)
      Entra no JAR final: SIM
      Uso típico: implementação de interface (JDBC driver, logging impl)

      Por que runtime?
      Você COMPILA contra a INTERFACE (SLF4J), mas em RUNTIME
      precisa de uma IMPLEMENTAÇÃO (Logback). O código Java não
      importa Logback diretamente — só o SLF4J. Então Logback
      não precisa estar no classpath de compilação.

      Isso é o princípio de Design "programa para interfaces,
      não implementações" — e o Maven scope enforcement o garante!
      ───────────────────────────────────────────────────── -->
    <dependency>
      <groupId>ch.qos.logback</groupId>
      <artifactId>logback-classic</artifactId>
      <version>${logback.version}</version>
      <scope>runtime</scope>
    </dependency>

    <!-- Driver JDBC do H2 (banco em memória) — runtime porque -->
    <!-- o código compila com java.sql.* (interfaces do JDK),  -->
    <!-- não com classes específicas do H2                      -->
    <dependency>
      <groupId>com.h2database</groupId>
      <artifactId>h2</artifactId>
      <version>${h2.version}</version>
      <scope>runtime</scope>
    </dependency>

    <!-- ─────────────────────────────────────────────────────
      ESCOPO: provided

      Disponível em: compilação + teste
      NÃO disponível em: runtime (não entra no JAR final)
      Entra no JAR final: NÃO
      Uso típico: APIs que o SERVIDOR DE APLICAÇÃO já fornece

      Exemplos clássicos:
      - Servlet API (o Tomcat/JBoss já tem)
      - Jakarta EE APIs (o servidor já tem)

      Analogia: é como a iluminação de uma loja em um shopping.
      O shopping já tem a iluminação — você não precisa trazer
      as lâmpadas (mas precisa saber que elas existem para
      projetar a loja).
      ───────────────────────────────────────────────────── -->
    <dependency>
      <groupId>jakarta.servlet</groupId>
      <artifactId>jakarta.servlet-api</artifactId>
      <version>6.0.0</version>
      <scope>provided</scope>
    </dependency>

    <!-- Lombok: gera código (getters, setters, etc.) em tempo de compilação -->
    <!-- O JAR do Lombok não precisa ir para produção — só processa anotações -->
    <dependency>
      <groupId>org.projectlombok</groupId>
      <artifactId>lombok</artifactId>
      <version>${lombok.version}</version>
      <scope>provided</scope>
    </dependency>

    <!-- ─────────────────────────────────────────────────────
      ESCOPO: test

      Disponível em: compilação de testes + execução de testes
      NÃO disponível em: código de produção + JAR final
      Entra no JAR final: NÃO
      Uso típico: frameworks de teste (JUnit, Mockito, AssertJ)
      ───────────────────────────────────────────────────── -->

    <!-- JUnit 5 API — para escrever testes -->
    <dependency>
      <groupId>org.junit.jupiter</groupId>
      <artifactId>junit-jupiter-api</artifactId>
      <version>${junit.version}</version>
      <scope>test</scope>
    </dependency>

    <!-- JUnit 5 Engine — para EXECUTAR os testes -->
    <dependency>
      <groupId>org.junit.jupiter</groupId>
      <artifactId>junit-jupiter-engine</artifactId>
      <version>${junit.version}</version>
      <scope>test</scope>
    </dependency>

    <!-- Mockito — para criar mocks nos testes -->
    <dependency>
      <groupId>org.mockito</groupId>
      <artifactId>mockito-core</artifactId>
      <version>5.7.0</version>
      <scope>test</scope>
    </dependency>

    <!-- AssertJ — biblioteca de assertions mais expressiva que JUnit padrão -->
    <dependency>
      <groupId>org.assertj</groupId>
      <artifactId>assertj-core</artifactId>
      <version>3.24.2</version>
      <scope>test</scope>
    </dependency>

    <!-- ─────────────────────────────────────────────────────
      ESCOPO: import (especial — só para POMs)
      Veja o arquivo 03-pom-bom.xml para detalhes sobre import
      ───────────────────────────────────────────────────── -->

  </dependencies>

  <!-- ═══════════════════════════════════════════════════════
    SEÇÃO: build > plugins
    Configura o maven-surefire-plugin para JUnit 5.
    Por padrão, o Maven usa uma versão antiga do surefire
    que não suporta JUnit 5 — precisamos atualizar.
    ═══════════════════════════════════════════════════════ -->
  <build>
    <plugins>
      <plugin>
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-surefire-plugin</artifactId>
        <version>3.2.2</version>
        <!-- Configuração necessária para usar JUnit 5 (Jupiter) -->
        <!-- Sem isso, o Maven pode não encontrar/executar os testes JUnit 5 -->
      </plugin>
    </plugins>
  </build>

</project>

<!--
  ═══════════════════════════════════════════════════════════
  RESUMO DOS ESCOPOS:

  Escopo    │ Compile │ Runtime │ Test │ Entra no JAR
  ──────────┼─────────┼─────────┼──────┼─────────────
  compile   │   SIM   │   SIM   │  SIM │     SIM
  runtime   │   NÃO   │   SIM   │  SIM │     SIM
  provided  │   SIM   │   NÃO   │  SIM │     NÃO
  test      │   NÃO   │   NÃO   │  SIM │     NÃO
  system    │   SIM   │   NÃO   │  SIM │     NÃO (obsoleto)
  import    │ (especial — só para POMs de BOM)
  ═══════════════════════════════════════════════════════════
-->
