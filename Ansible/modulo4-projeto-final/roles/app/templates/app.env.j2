# ==============================================================
# ARQUIVO: roles/app/templates/app.env.j2
# MÓDULO 4 - Projeto Final
# ==============================================================
#
# 🧒 EXPLICAÇÃO SIMPLES:
# O arquivo .env é como uma "ficha técnica secreta" da aplicação.
# Contém configurações que MUDAM entre ambientes (prod, staging).
# NÃO vai para o Git! Gerado pelo Ansible com dados do vault.
# ==============================================================

# Gerado automaticamente pelo Ansible
# Data: {{ ansible_date_time.date | default('hoje') }}
# Host: {{ inventory_hostname }}
# Ambiente: {{ ambiente | upper }}
# NÃO edite manualmente - será sobrescrito no próximo deploy!

# ---- Configurações da Aplicação -----------------------------
APP_NAME="{{ app_nome }}"
APP_ENV="{{ ambiente }}"
APP_DEBUG="{{ 'True' if ambiente == 'staging' else 'False' }}"
APP_PORT="{{ app_porta }}"
APP_SECRET_KEY="{{ vault_app_secret_key | default('chave-padrao-insegura') }}"
APP_JWT_SECRET="{{ vault_app_jwt_secret | default('jwt-padrao-inseguro') }}"

# ---- Banco de Dados -----------------------------------------
DATABASE_URL="postgresql://{{ db_usuario }}:{{ vault_db_senha | default('senha') }}@localhost:{{ db_porta }}/{{ db_nome }}"
DB_HOST="localhost"
DB_PORT="{{ db_porta }}"
DB_NAME="{{ db_nome }}"
DB_USER="{{ db_usuario }}"
DB_PASSWORD="{{ vault_db_senha | default('senha') }}"

# ---- Email --------------------------------------------------
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="{{ vault_smtp_usuario | default('') }}"
SMTP_PASSWORD="{{ vault_smtp_senha | default('') }}"
SMTP_FROM="noreply@{{ nginx_dominio }}"

# ---- Configurações condicionais por ambiente ----------------
{% if ambiente == "producao" %}
# Produção: logs mínimos, sem debug, cache agressivo
LOG_LEVEL="WARNING"
CACHE_TTL="3600"
ALLOWED_HOSTS="{{ nginx_dominio }}"
{% else %}
# Staging/Dev: logs verbosos, debug ativo
LOG_LEVEL="DEBUG"
CACHE_TTL="60"
ALLOWED_HOSTS="*"
{% endif %}
